{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "esnext",
    "types": ["node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    /* Added by me */
    "allowJs": true,
    "checkJs": true,
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "eslint.config.mts",
    "prettier.config.mts",
    "eslint-plugin-prefer-arrow-functions.d.ts"
  ]
}
